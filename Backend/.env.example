# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key-here

# ── Flask / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_random_secret
FLASK_DEBUG=true
FLASK_PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=workeval.db

# ── Admin Seed Account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@workeval.com
ADMIN_PASSWORD=change_this_password
ADMIN_NAME=Admin
ADMIN_DEPARTMENT=HR

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
